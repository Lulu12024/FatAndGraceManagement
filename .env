# ── Django ────────────────────────────────
SECRET_KEY=django-insecure-%ckybrzgg-oms^kg2^m*3sp)zgjzrjeg18ww7h+5k5u0l8#3=w
DEBUG=False
ALLOWED_HOSTS=*

# ── Base de données PostgreSQL ────────────
# DB_HOST est automatiquement "db" (nom du service Docker)
DB_NAME=stock_db
DB_USER=postgres
DB_PASSWORD=#!@dm1n!#
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────
# REDIS_HOST est automatiquement "redis" (nom du service Docker)
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ───────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ── Superutilisateur initial ──────────────
